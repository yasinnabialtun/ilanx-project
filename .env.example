# İlanX - Çevre Değişkenleri Şablonu
# Bu dosyayı '.env.local' olarak kopyalayıp kendi şifrelerinizi belirleyin.

# 1. Lisans Güvenlik Anahtarı (JWT Şifrelemesi için)
# Bu anahtar, üretilen lisans jetonlarının güvenli bir şekilde imzalanmasını sağlar. 
# Canlıya alırken çok karmaşık ve benzersiz bir şifre girin.
JWT_SECRET=ilanx_license_secret_signature_key_2026_super_secure

# 2. Yönetici Arayüzü Giriş Şifresi
# '/admin' paneline erişirken ve yeni lisans anahtarı üretirken girilecek olan şifredir.
ADMIN_SECRET=ilanx_admin_secret_key_2026_super_secure
